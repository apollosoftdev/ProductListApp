<Window
    x:Class="LedgerDesk.KeyGen.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="LedgerDesk Key Generator">

    <Grid Padding="32">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                    MaxWidth="480" Spacing="24">

            <!-- Title -->
            <StackPanel HorizontalAlignment="Center" Spacing="8">
                <FontIcon Glyph="&#xE8D7;" FontSize="48"
                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                          HorizontalAlignment="Center"/>
                <TextBlock Text="LedgerDesk Key Generator" FontSize="22" FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Generate license keys from device serial numbers"
                           FontSize="13"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Serial Number Input -->
            <TextBox x:Name="SnInput" Header="Serial Number"
                     PlaceholderText="e.g. A1B2-C3D4-E5F6-7890"
                     FontFamily="Cascadia Code,Consolas,Courier New"
                     HorizontalAlignment="Stretch"/>

            <!-- Generate Button -->
            <Button Content="Generate Key" Style="{StaticResource AccentButtonStyle}"
                    HorizontalAlignment="Stretch" Click="Generate_Click"/>

            <!-- Result -->
            <Border x:Name="ResultPanel" CornerRadius="8" Padding="20"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    Visibility="Collapsed">
                <StackPanel Spacing="8">
                    <TextBlock Text="Generated License Key" FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock x:Name="ResultKey" FontSize="20" FontWeight="SemiBold"
                               FontFamily="Cascadia Code,Consolas,Courier New"
                               IsTextSelectionEnabled="True"
                               HorizontalAlignment="Center"/>
                    <Button Content="Copy to Clipboard" HorizontalAlignment="Center"
                            Click="Copy_Click" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Error -->
            <TextBlock x:Name="ErrorText" Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                       FontSize="13" Visibility="Collapsed" HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
