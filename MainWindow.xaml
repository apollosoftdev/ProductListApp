<Window
    x:Class="LedgerDesk.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:LedgerDesk"
    xmlns:helpers="using:LedgerDesk.Helpers"
    Title="LedgerDesk">

    <Grid x:Name="RootGrid">
        <Grid.Resources>
            <helpers:BoolToVisibilityConverter x:Key="BoolToVisible"/>
            <helpers:BoolToVisibilityConverter x:Key="BoolToCollapsed" Invert="True"/>
            <helpers:AmountToColorConverter x:Key="AmountToColor"/>
            <Style x:Key="CloseIconButton" TargetType="Button">
                <Setter Property="Width" Value="32"/>
                <Setter Property="Height" Value="32"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="CornerRadius" Value="16"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="HorizontalAlignment" Value="Right"/>
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Padding="16,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <FontIcon Glyph="&#xE719;" FontSize="16"
                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                          Margin="0,0,10,0"/>
                <TextBlock Text="LedgerDesk" Style="{StaticResource CaptionTextBlockStyle}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- ==================== Main Panel ==================== -->
        <Grid x:Name="MainPanel" Grid.Row="1" Padding="32,16,32,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- Header -->
                <RowDefinition Height="Auto"/>   <!-- Stats -->
                <RowDefinition Height="Auto"/>   <!-- Filter bar placeholder -->
                <RowDefinition Height="*"/>      <!-- Table -->
                <RowDefinition Height="Auto"/>   <!-- Status bar -->
            </Grid.RowDefinitions>

            <!-- Page Header -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="DashboardTitle" Text="Dashboard" Style="{StaticResource TitleTextBlockStyle}"/>
                    <TextBlock x:Name="SubtitleText" Text="Transaction history overview"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                            VerticalAlignment="Center">
                    <Button Click="RefreshButton_Click" ToolTipService.ToolTip="Refresh">
                        <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                    </Button>
                    <Button Click="SettingsButton_Click" ToolTipService.ToolTip="Settings">
                        <FontIcon Glyph="&#xE713;" FontSize="14"/>
                    </Button>
                    <Button Style="{StaticResource AccentButtonStyle}"
                            Click="NewRecordButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE710;" FontSize="14"/>
                            <TextBlock x:Name="NewRecordButtonText" Text="New Record"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Stats Cards -->
            <Grid Grid.Row="1" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Total Records -->
                <Border Grid.Column="0" CornerRadius="8" Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock x:Name="StatTotalLabel" Text="Total Records" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock x:Name="StatTotal" Text="{Binding TotalRecords}"
                                   FontSize="28" FontWeight="SemiBold" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Total Income -->
                <Border Grid.Column="2" CornerRadius="8" Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock x:Name="StatIncomeLabel" Text="Total Income" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="{Binding TotalIncome}"
                                   FontSize="28" FontWeight="SemiBold" Margin="0,4,0,0"
                                   Foreground="#10B981"/>
                    </StackPanel>
                </Border>

                <!-- Total Expense -->
                <Border Grid.Column="4" CornerRadius="8" Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock x:Name="StatExpenseLabel" Text="Total Expense" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="{Binding TotalExpense}"
                                   FontSize="28" FontWeight="SemiBold" Margin="0,4,0,0"
                                   Foreground="#EF4444"/>
                    </StackPanel>
                </Border>

                <!-- Balance -->
                <Border Grid.Column="6" CornerRadius="8" Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock x:Name="StatBalanceLabel" Text="Balance" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="{Binding Balance}"
                                   FontSize="28" FontWeight="SemiBold" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Filter Bar -->
            <Grid Grid.Row="2" Margin="0,0,0,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Row 1: Title, Category, Description -->
                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="FilterTitle" Grid.Column="0"
                             PlaceholderText="Search title..."
                             TextChanged="FilterText_Changed"/>

                    <ComboBox x:Name="FilterCategory" Grid.Column="2"
                              PlaceholderText="All Categories" Width="160"
                              SelectionChanged="FilterCategory_Changed"/>

                    <TextBox x:Name="FilterDescription" Grid.Column="4"
                             PlaceholderText="Search description..."
                             TextChanged="FilterText_Changed"/>
                </Grid>

                <!-- Row 2: Amount range, Date range, Clear -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <NumberBox x:Name="FilterAmountMin" Grid.Column="0"
                               PlaceholderText="Min amount" Width="130"
                               SpinButtonPlacementMode="Hidden"
                               ValueChanged="FilterAmount_Changed"/>
                    <NumberBox x:Name="FilterAmountMax" Grid.Column="2"
                               PlaceholderText="Max amount" Width="130"
                               SpinButtonPlacementMode="Hidden"
                               ValueChanged="FilterAmount_Changed"/>

                    <CalendarDatePicker x:Name="FilterDateStart" Grid.Column="4"
                                        PlaceholderText="From date"
                                        DateChanged="FilterDate_Changed"/>
                    <CalendarDatePicker x:Name="FilterDateEnd" Grid.Column="6"
                                        PlaceholderText="To date"
                                        DateChanged="FilterDate_Changed"/>

                    <Button x:Name="ClearFiltersButton" Grid.Column="8"
                            Click="ClearFilters_Click"
                            Visibility="Collapsed"
                            ToolTipService.ToolTip="Clear all filters">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE894;" FontSize="12"/>
                            <TextBlock x:Name="ClearFiltersText" Text="Clear"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>

            <!-- Record Table -->
            <Grid Grid.Row="3">
                <Border CornerRadius="8" BorderThickness="1"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Table Header -->
                        <Border Grid.Row="0" Padding="20,14"
                                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                CornerRadius="8,8,0,0"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>  <!-- Date -->
                                    <ColumnDefinition Width="140"/>   <!-- Type -->
                                    <ColumnDefinition Width="2.5*"/>  <!-- Title -->
                                    <ColumnDefinition Width="1.2*"/>  <!-- Category -->
                                    <ColumnDefinition Width="120"/>  <!-- Amount -->
                                    <ColumnDefinition Width="44"/>   <!-- Image indicator -->
                                </Grid.ColumnDefinitions>

                                <TextBlock x:Name="ColDate" Grid.Column="0" Text="DATE"
                                           FontSize="12" FontWeight="SemiBold" CharacterSpacing="60"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock x:Name="ColType" Grid.Column="1" Text="TYPE"
                                           FontSize="12" FontWeight="SemiBold" CharacterSpacing="60"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock x:Name="ColTitle" Grid.Column="2" Text="TITLE"
                                           FontSize="12" FontWeight="SemiBold" CharacterSpacing="60"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock x:Name="ColCategory" Grid.Column="3" Text="CATEGORY"
                                           FontSize="12" FontWeight="SemiBold" CharacterSpacing="60"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock x:Name="ColAmount" Grid.Column="4" Text="AMOUNT"
                                           FontSize="12" FontWeight="SemiBold" CharacterSpacing="60"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           HorizontalAlignment="Right" Margin="0,0,12,0"/>
                                <FontIcon Grid.Column="5" Glyph="&#xE722;" FontSize="12"
                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                          HorizontalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Record Rows -->
                        <ListView x:Name="RecordListView" Grid.Row="1"
                                  ItemsSource="{Binding Records}"
                                  SelectionMode="Single"
                                  IsItemClickEnabled="True"
                                  ItemClick="RecordListView_ItemClick"
                                  Padding="0" Margin="0">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="20,10"
                                          BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                          BorderThickness="0,0,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="2.5*"/>
                                            <ColumnDefinition Width="1.2*"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="44"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Date -->
                                        <TextBlock Grid.Column="0" Text="{Binding DateDisplay}"
                                                   FontSize="13"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   VerticalAlignment="Center"/>

                                        <!-- Balance Type -->
                                        <TextBlock Grid.Column="1" Text="{Binding BalanceTypeDisplay}"
                                                   FontSize="11" VerticalAlignment="Center"
                                                   Foreground="{Binding Amount, Converter={StaticResource AmountToColor}}"/>

                                        <!-- Title -->
                                        <TextBlock Grid.Column="2" Text="{Binding Title}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <!-- Category Badge -->
                                        <Border Grid.Column="3"
                                                Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                CornerRadius="12" Padding="10,4"
                                                HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Category}" FontSize="11"
                                                       FontWeight="Medium"
                                                       Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
                                        </Border>

                                        <!-- Amount -->
                                        <TextBlock Grid.Column="4" Text="{Binding AmountDisplay}"
                                                   FontSize="13"
                                                   FontFamily="Cascadia Code,Consolas,Courier New"
                                                   HorizontalAlignment="Right" Margin="0,0,12,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="{Binding Amount, Converter={StaticResource AmountToColor}}"/>

                                        <!-- Image Indicator -->
                                        <FontIcon Grid.Column="5" Glyph="&#xE722;" FontSize="14"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                                  Visibility="{Binding HasImages, Converter={StaticResource BoolToVisible}}"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="MinHeight" Value="0"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                        </ListView>

                        <!-- Empty State -->
                        <StackPanel x:Name="EmptyState" Grid.Row="1"
                                    VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Visibility="{Binding HasRecords, Converter={StaticResource BoolToCollapsed}}">
                            <FontIcon Glyph="&#xE9F9;" FontSize="48"
                                      Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                      HorizontalAlignment="Center" Margin="0,0,0,12"/>
                            <TextBlock x:Name="EmptyTitle" Text="No records yet" FontSize="16" FontWeight="SemiBold"
                                       HorizontalAlignment="Center"/>
                            <TextBlock x:Name="EmptySubtitle" Text="Click 'New Record' to add your first transaction"
                                       FontSize="13"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- Status Bar -->
            <Grid Grid.Row="4" Margin="0,10,0,0">
                <TextBlock Text="{Binding StatusText}" FontSize="12"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
            </Grid>
        </Grid>

        <!-- ==================== Activation Panel ==================== -->
        <Grid x:Name="ActivationPanel" Grid.Row="1" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        MaxWidth="420" MinWidth="360" Spacing="20">
                <!-- Icon + Title -->
                <StackPanel HorizontalAlignment="Center" Spacing="8">
                    <FontIcon Glyph="&#xE72E;" FontSize="48"
                              Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                              HorizontalAlignment="Center"/>
                    <TextBlock x:Name="ActivationTitle" Text="License Activation" FontSize="24" FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="ActivationSubtitle" Text="Enter your license key to activate LedgerDesk"
                               FontSize="13"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- MAC Address -->
                <Border CornerRadius="8" Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel Spacing="4">
                        <TextBlock x:Name="ActivationMacLabel" Text="Device ID (MAC Address)" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock x:Name="ActivationMacAddress"
                                   FontSize="16" FontFamily="Cascadia Code,Consolas,Courier New"
                                   IsTextSelectionEnabled="True"/>
                    </StackPanel>
                </Border>

                <!-- License Key Input -->
                <TextBox x:Name="ActivationKeyInput" Header="License Key"
                         PlaceholderText="XXXXX-XXXXX-XXXXX-XXXXX-XXXXX"
                         FontFamily="Cascadia Code,Consolas,Courier New"
                         MaxLength="29" HorizontalAlignment="Stretch"/>

                <!-- Error Message -->
                <TextBlock x:Name="ActivationError" Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                           FontSize="13" Visibility="Collapsed"
                           HorizontalAlignment="Center"/>

                <!-- Activate Button -->
                <Button x:Name="ActivateButton" Content="Activate" Style="{StaticResource AccentButtonStyle}"
                        HorizontalAlignment="Stretch" Click="Activate_Click"/>
            </StackPanel>
        </Grid>

        <!-- ==================== Login Panel ==================== -->
        <Grid x:Name="LoginPanel" Grid.Row="1" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        MaxWidth="360" MinWidth="320" Spacing="20">
                <!-- Icon + Title -->
                <StackPanel HorizontalAlignment="Center" Spacing="8">
                    <FontIcon Glyph="&#xE77B;" FontSize="48"
                              Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                              HorizontalAlignment="Center"/>
                    <TextBlock x:Name="LoginTitle" Text="Welcome Back" FontSize="24" FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="LoginSubtitle" Text="Enter your password to continue"
                               FontSize="13"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Password -->
                <PasswordBox x:Name="LoginPassword" Header="Password"
                             PlaceholderText="Enter password"
                             KeyDown="LoginPassword_KeyDown"/>

                <!-- Confirm Password (first run only) -->
                <PasswordBox x:Name="LoginConfirmPassword" Header="Confirm Password"
                             PlaceholderText="Re-enter password"
                             Visibility="Collapsed"
                             KeyDown="LoginPassword_KeyDown"/>

                <!-- Error Message -->
                <TextBlock x:Name="LoginError" Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                           FontSize="13" Visibility="Collapsed"
                           HorizontalAlignment="Center"/>

                <!-- Login Button -->
                <Button x:Name="LoginButton" Content="Login"
                        Style="{StaticResource AccentButtonStyle}"
                        HorizontalAlignment="Stretch" Click="Login_Click"/>
            </StackPanel>
        </Grid>

        <!-- ==================== Record Sheet Overlay (Detail / Add / Edit) ==================== -->
        <Grid x:Name="SidePanel" Grid.Row="0" Grid.RowSpan="2" Visibility="Collapsed">
            <Border Background="#80000000" PointerPressed="SidePanelBackdrop_Click"/>

            <Border HorizontalAlignment="Right" Width="460"
                    Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1,0,0,0">
                <Grid Padding="24,56,24,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock x:Name="SidePanelHeaderText" FontSize="20" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <Button Style="{StaticResource CloseIconButton}"
                                Click="CloseSidePanel_Click" ToolTipService.ToolTip="Close">
                            <FontIcon Glyph="&#xE711;" FontSize="12"/>
                        </Button>
                    </Grid>

                    <!-- Content -->
                    <Grid Grid.Row="1">
                        <!-- ===== Detail View ===== -->
                        <ScrollViewer x:Name="SidePanelDetail" VerticalScrollBarVisibility="Auto"
                                      Visibility="Collapsed">
                            <StackPanel Spacing="14">
                                <!-- Detail Images -->
                                <FlipView x:Name="DetailImageGallery" Height="200"
                                          Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                          CornerRadius="8" x:Load="True"
                                          Visibility="Collapsed">
                                    <FlipView.ItemTemplate>
                                        <DataTemplate>
                                            <Image Source="{Binding ImageSource}" Stretch="Uniform"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </FlipView.ItemTemplate>
                                </FlipView>

                                <!-- Title -->
                                <TextBlock x:Name="DetailTitle" FontSize="20" FontWeight="SemiBold"
                                           TextWrapping="Wrap"/>

                                <!-- Type + Category + Date -->
                                <StackPanel Spacing="8">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <Border x:Name="DetailBalanceTypeBorder" CornerRadius="12" Padding="10,4">
                                            <TextBlock x:Name="DetailBalanceType" FontSize="11" FontWeight="Medium"
                                                       Foreground="White"/>
                                        </Border>
                                        <Border Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                CornerRadius="12" Padding="10,4">
                                            <TextBlock x:Name="DetailCategory" FontSize="11" FontWeight="Medium"
                                                       Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
                                        </Border>
                                        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                            <FontIcon Glyph="&#xE787;" FontSize="12"
                                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            <TextBlock x:Name="DetailDate" FontSize="12"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Amount -->
                                <StackPanel>
                                    <TextBlock x:Name="DetailAmountLabel" Text="Amount" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock x:Name="DetailAmount" FontSize="28" FontWeight="Bold"
                                               FontFamily="Cascadia Code,Consolas,Courier New"
                                               Margin="0,4,0,0"/>
                                </StackPanel>

                                <!-- Description -->
                                <StackPanel x:Name="DetailDescriptionSection">
                                    <TextBlock x:Name="DetailDescLabel" Text="Description" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock x:Name="DetailDescription" FontSize="13"
                                               TextWrapping="Wrap" Margin="0,4,0,0"/>
                                </StackPanel>

                                <!-- Actions -->
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" HorizontalAlignment="Stretch"
                                            Click="DetailEdit_Click">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE70F;" FontSize="14"/>
                                            <TextBlock x:Name="DetailEditText" Text="Edit"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Grid.Column="2" HorizontalAlignment="Stretch"
                                            Click="DetailDelete_Click">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE74D;" FontSize="14"
                                                      Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                            <TextBlock x:Name="DetailDeleteText" Text="Delete"
                                                       Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- ===== Add/Edit Form ===== -->
                        <ScrollViewer x:Name="SidePanelForm" VerticalScrollBarVisibility="Auto"
                                      Visibility="Collapsed">
                            <StackPanel Spacing="14">
                                <!-- Image Drop Zone -->
                                <Grid x:Name="FormImageDropZone" MinHeight="100" CornerRadius="8"
                                      Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                      BorderThickness="1" AllowDrop="True"
                                      DragOver="FormImageDropZone_DragOver"
                                      Drop="FormImageDropZone_Drop">
                                    <ItemsControl x:Name="FormImageList" Margin="8"
                                                  Visibility="Collapsed">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <ItemsWrapGrid Orientation="Horizontal"
                                                               ItemWidth="76" ItemHeight="76"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Width="72" Height="72" CornerRadius="6"
                                                      Margin="0,0,0,4">
                                                    <Image Source="{Binding ImageSource}" Stretch="UniformToFill"/>
                                                    <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                                                            Width="20" Height="20" Padding="0"
                                                            Click="RemoveImage_Click" Tag="{Binding}"
                                                            CornerRadius="10"
                                                            Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}">
                                                        <FontIcon Glyph="&#xE711;" FontSize="8"
                                                                  Foreground="White"/>
                                                    </Button>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <StackPanel x:Name="FormImagePlaceholder" VerticalAlignment="Center"
                                                HorizontalAlignment="Center" Spacing="4">
                                        <FontIcon Glyph="&#xE722;" FontSize="24"
                                                  HorizontalAlignment="Center"
                                                  Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                        <TextBlock x:Name="FormImageDropText" Text="Drag images here or" FontSize="12"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <HyperlinkButton x:Name="FormImageBrowseLink" Content="Browse files" Click="BrowseImage_Click"
                                                         HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Balance Type -->
                                <StackPanel Spacing="4">
                                    <TextBlock x:Name="FormBalanceTypeLabel" Text="Balance Type" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="4"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <ToggleButton x:Name="FormIncomeToggle" Grid.Column="0"
                                                      Content="Income" HorizontalAlignment="Stretch"
                                                      IsChecked="True" Click="BalanceType_Click"/>
                                        <ToggleButton x:Name="FormExpenseToggle" Grid.Column="2"
                                                      Content="Expense" HorizontalAlignment="Stretch"
                                                      Click="BalanceType_Click"/>
                                    </Grid>
                                </StackPanel>

                                <TextBox x:Name="FormTitle" Header="Title"
                                         PlaceholderText="e.g. Office Supplies"/>
                                <ComboBox x:Name="FormCategory" Header="Category"
                                          IsEditable="True" PlaceholderText="Select or type..."
                                          HorizontalAlignment="Stretch"/>
                                <NumberBox x:Name="FormAmount" Header="Amount"
                                           PlaceholderText="0.00" Minimum="0"
                                           SpinButtonPlacementMode="Compact"
                                           SmallChange="1" LargeChange="100"/>
                                <CalendarDatePicker x:Name="FormDate" Header="Date"
                                                    HorizontalAlignment="Stretch"
                                                    PlaceholderText="Select date"/>
                                <TextBox x:Name="FormDescription" Header="Description"
                                         PlaceholderText="Add details..."
                                         AcceptsReturn="True" TextWrapping="Wrap" MinHeight="80"/>

                                <!-- Action Buttons -->
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="FormCancelButton" Grid.Column="0" Content="Cancel"
                                            HorizontalAlignment="Stretch"
                                            Click="CloseSidePanel_Click"/>
                                    <Button x:Name="FormSaveButton" Grid.Column="2" Content="Save"
                                            Style="{StaticResource AccentButtonStyle}"
                                            HorizontalAlignment="Stretch"
                                            Click="SaveRecord_Click"/>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- ==================== Settings Overlay Sheet ==================== -->
        <Grid x:Name="SettingsPanel" Grid.Row="0" Grid.RowSpan="2" Visibility="Collapsed">
            <!-- Dimmed backdrop -->
            <Border Background="#80000000" PointerPressed="SettingsBackdrop_Click"/>

            <!-- Sheet -->
            <Border HorizontalAlignment="Right" Width="500"
                    Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1,0,0,0">
                <Grid Padding="28,56,28,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock x:Name="SettingsTitleText" Text="Settings" FontSize="22" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <Button Style="{StaticResource CloseIconButton}"
                                Click="SettingsBack_Click" ToolTipService.ToolTip="Close">
                            <FontIcon Glyph="&#xE711;" FontSize="12"/>
                        </Button>
                    </Grid>

                    <!-- Settings Content -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="24">

                            <!-- ===== Security ===== -->
                            <Border CornerRadius="8" Padding="20"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                <StackPanel Spacing="12">
                                    <TextBlock x:Name="SettingsSecurityLabel" Text="Security" FontSize="16" FontWeight="SemiBold"/>
                                    <PasswordBox x:Name="SettingsOldPassword" Header="Current Password"
                                                 PlaceholderText="Enter current password"/>
                                    <PasswordBox x:Name="SettingsNewPassword" Header="New Password"
                                                 PlaceholderText="Enter new password"/>
                                    <PasswordBox x:Name="SettingsConfirmPassword" Header="Confirm New Password"
                                                 PlaceholderText="Re-enter new password"/>
                                    <TextBlock x:Name="SettingsPasswordMessage" FontSize="13"
                                               Visibility="Collapsed"/>
                                    <Button x:Name="SettingsChangePasswordBtn" Content="Change Password" Click="ChangePassword_Click"/>
                                </StackPanel>
                            </Border>

                            <!-- ===== Categories ===== -->
                            <Border CornerRadius="8" Padding="20"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                <StackPanel Spacing="12">
                                    <TextBlock x:Name="SettingsCategoriesLabel" Text="Categories" FontSize="16" FontWeight="SemiBold"/>

                                    <ListView x:Name="SettingsCategoryList" SelectionMode="None"
                                              MaxHeight="250">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Padding="4,6" ColumnSpacing="8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                               VerticalAlignment="Center" FontSize="14"/>
                                                    <Button Grid.Column="1" Click="DeleteCategory_Click"
                                                            Tag="{Binding}" Padding="6,4"
                                                            ToolTipService.ToolTip="Delete category">
                                                        <FontIcon Glyph="&#xE74D;" FontSize="12"
                                                                  Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                                    </Button>
                                                </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                        <ListView.ItemContainerStyle>
                                            <Style TargetType="ListViewItem">
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                <Setter Property="Padding" Value="0"/>
                                                <Setter Property="MinHeight" Value="0"/>
                                            </Style>
                                        </ListView.ItemContainerStyle>
                                    </ListView>

                                    <!-- Add Category -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="SettingsNewCategory" Grid.Column="0"
                                                 PlaceholderText="New category name"/>
                                        <Button x:Name="SettingsAddCategoryBtn" Grid.Column="2" Content="Add" Click="AddCategory_Click"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- ===== Theme ===== -->
                            <Border CornerRadius="8" Padding="20"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                <StackPanel Spacing="12">
                                    <TextBlock x:Name="SettingsThemeLabel" Text="Theme" FontSize="16" FontWeight="SemiBold"/>
                                    <RadioButtons x:Name="SettingsTheme" SelectionChanged="ThemeChanged">
                                        <RadioButton x:Name="ThemeDefault" Content="System Default" Tag="Default"/>
                                        <RadioButton x:Name="ThemeLight" Content="Light" Tag="Light"/>
                                        <RadioButton x:Name="ThemeDark" Content="Dark" Tag="Dark"/>
                                    </RadioButtons>
                                </StackPanel>
                            </Border>

                            <!-- ===== Language ===== -->
                            <Border CornerRadius="8" Padding="20"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                <StackPanel Spacing="12">
                                    <TextBlock x:Name="SettingsLanguageLabel" Text="Language" FontSize="16" FontWeight="SemiBold"/>
                                    <ComboBox x:Name="SettingsLanguage" Width="200"
                                              SelectionChanged="LanguageChanged"/>
                                </StackPanel>
                            </Border>

                            <!-- ===== UI Text Customization ===== -->
                            <Border CornerRadius="8" Padding="20"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                <StackPanel Spacing="12">
                                    <Grid>
                                        <TextBlock x:Name="SettingsTextCustomLabel" Text="UI Text Customization"
                                                   FontSize="16" FontWeight="SemiBold"/>
                                        <Button x:Name="SettingsTextResetButton" Content="Reset to Default"
                                                HorizontalAlignment="Right" Click="ResetTextOverrides_Click"/>
                                    </Grid>
                                    <ListView x:Name="SettingsTextList" MaxHeight="300" SelectionMode="None">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Padding="2,4" ColumnSpacing="8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="160"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding Key}"
                                                               FontSize="11" VerticalAlignment="Center"
                                                               FontFamily="Cascadia Code,Consolas,Courier New"
                                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBox Grid.Column="1" Text="{Binding Value}"
                                                             FontSize="12"
                                                             LostFocus="TextOverride_LostFocus"
                                                             Tag="{Binding Key}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                        <ListView.ItemContainerStyle>
                                            <Style TargetType="ListViewItem">
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                <Setter Property="Padding" Value="0"/>
                                                <Setter Property="MinHeight" Value="0"/>
                                            </Style>
                                        </ListView.ItemContainerStyle>
                                    </ListView>
                                </StackPanel>
                            </Border>

                            <!-- ===== License Info ===== -->
                            <Border CornerRadius="8" Padding="20"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                <StackPanel Spacing="12">
                                    <TextBlock x:Name="SettingsLicenseLabel" Text="License Info" FontSize="16" FontWeight="SemiBold"/>
                                    <StackPanel Spacing="4">
                                        <TextBlock x:Name="SettingsMacLabel" Text="Device ID (MAC Address)" FontSize="12"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock x:Name="SettingsMacAddress"
                                                   FontFamily="Cascadia Code,Consolas,Courier New"
                                                   IsTextSelectionEnabled="True"/>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock x:Name="SettingsKeyLabel" Text="License Key" FontSize="12"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock x:Name="SettingsLicenseKey"
                                                   FontFamily="Cascadia Code,Consolas,Courier New"
                                                   IsTextSelectionEnabled="True"/>
                                    </StackPanel>
                                    <Button x:Name="SettingsDeactivateBtn" Content="Deactivate License" Click="DeactivateLicense_Click"/>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
