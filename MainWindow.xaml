<Window
    x:Class="ProductListApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ProductListApp"
    xmlns:helpers="using:ProductListApp.Helpers"
    Title="Product Manager">

    <Grid>
        <Grid.Resources>
            <helpers:BoolToVisibilityConverter x:Key="BoolToVisible"/>
            <helpers:BoolToVisibilityConverter x:Key="BoolToCollapsed" Invert="True"/>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Padding="16,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <FontIcon Glyph="&#xE719;" FontSize="16"
                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                          Margin="0,0,10,0"/>
                <TextBlock Text="Product Manager" Style="{StaticResource CaptionTextBlockStyle}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Main Content -->
        <Grid Grid.Row="1" Padding="32,16,32,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Page Header -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Products" Style="{StaticResource TitleTextBlockStyle}"/>
                    <TextBlock x:Name="SubtitleText" Text="Manage your product inventory"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                            VerticalAlignment="Center">
                    <Button Click="RefreshButton_Click" ToolTipService.ToolTip="Refresh">
                        <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                    </Button>
                    <Button Style="{StaticResource AccentButtonStyle}"
                            Click="AddButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE710;" FontSize="14"/>
                            <TextBlock Text="Add Product"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Stats Cards -->
            <Grid Grid.Row="1" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Total Products -->
                <Border Grid.Column="0" CornerRadius="8" Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Total Products" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock x:Name="StatTotal" Text="0" FontSize="28" FontWeight="SemiBold"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Categories -->
                <Border Grid.Column="2" CornerRadius="8" Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Categories" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock x:Name="StatCategories" Text="0" FontSize="28" FontWeight="SemiBold"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Total Value -->
                <Border Grid.Column="4" CornerRadius="8" Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Total Value" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock x:Name="StatValue" Text="$0" FontSize="28" FontWeight="SemiBold"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Low Stock -->
                <Border Grid.Column="6" CornerRadius="8" Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Low Stock Items" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock x:Name="StatLowStock" Text="0" FontSize="28" FontWeight="SemiBold"
                                   Foreground="#E85D04" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Search & Filter Bar -->
            <Grid Grid.Row="2" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MaxWidth="400"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <AutoSuggestBox x:Name="SearchBox" Grid.Column="0"
                                QueryIcon="Find" PlaceholderText="Search products..."
                                TextChanged="SearchBox_TextChanged"/>

                <ComboBox x:Name="CategoryFilter" Grid.Column="2"
                          PlaceholderText="All Categories" Width="180"
                          SelectionChanged="CategoryFilter_SelectionChanged"/>

                <Button Grid.Column="4" Click="DeleteButton_Click"
                        ToolTipService.ToolTip="Delete selected product">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                        <TextBlock Text="Delete"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Product Table -->
            <Border Grid.Row="3" CornerRadius="8" BorderThickness="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Table Header -->
                    <Border Grid.Row="0" Padding="20,14"
                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                            CornerRadius="8,8,0,0"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="56"/>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="2*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="1" Text="#"
                                       FontSize="12" FontWeight="SemiBold" CharacterSpacing="60"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Grid.Column="2" Text="PRODUCT"
                                       FontSize="12" FontWeight="SemiBold" CharacterSpacing="60"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Grid.Column="3" Text="CATEGORY"
                                       FontSize="12" FontWeight="SemiBold" CharacterSpacing="60"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Grid.Column="4" Text="PRICE"
                                       FontSize="12" FontWeight="SemiBold" CharacterSpacing="60"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       HorizontalAlignment="Right" Margin="0,0,12,0"/>
                            <TextBlock Grid.Column="5" Text="STOCK"
                                       FontSize="12" FontWeight="SemiBold" CharacterSpacing="60"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="6" Text="DESCRIPTION"
                                       FontSize="12" FontWeight="SemiBold" CharacterSpacing="60"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Margin="12,0,0,0"/>
                        </Grid>
                    </Border>

                    <!-- Product Rows -->
                    <ListView x:Name="ProductListView" Grid.Row="1"
                              SelectionMode="Single"
                              Padding="0" Margin="0">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="20,8"
                                      BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                      BorderThickness="0,0,0,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="56"/>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="1.2*"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="2*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Thumbnail -->
                                    <Grid Grid.Column="0" Width="40" Height="40" CornerRadius="6"
                                          Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                          VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE722;" FontSize="16"
                                                  Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                  Visibility="{Binding HasImage, Converter={StaticResource BoolToCollapsed}}"/>
                                        <Image Source="{Binding ImageSource}" Stretch="UniformToFill"
                                               Visibility="{Binding HasImage, Converter={StaticResource BoolToVisible}}"/>
                                    </Grid>

                                    <!-- ID -->
                                    <TextBlock Grid.Column="1" Text="{Binding Id}"
                                               FontSize="13"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                               VerticalAlignment="Center"/>

                                    <!-- Product Name -->
                                    <TextBlock Grid.Column="2" Text="{Binding Name}"
                                               FontSize="13" FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>

                                    <!-- Category Badge -->
                                    <Border Grid.Column="3"
                                            Background="{ThemeResource AccentFillColorDefaultBrush}"
                                            CornerRadius="12" Padding="10,4"
                                            HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Category}" FontSize="11"
                                                   FontWeight="Medium"
                                                   Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
                                    </Border>

                                    <!-- Price -->
                                    <TextBlock Grid.Column="4" Text="{Binding PriceDisplay}"
                                               FontSize="13" FontFamily="Cascadia Code,Consolas,Courier New"
                                               HorizontalAlignment="Right" Margin="0,0,12,0"
                                               VerticalAlignment="Center"/>

                                    <!-- Stock -->
                                    <StackPanel Grid.Column="5" VerticalAlignment="Center"
                                                HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding Stock}" FontSize="13"
                                                   FontWeight="Medium"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding StockStatus}" FontSize="10"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                    </StackPanel>

                                    <!-- Description -->
                                    <TextBlock Grid.Column="6" Text="{Binding Description}"
                                               FontSize="12"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="12,0,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="MinHeight" Value="0"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                    </ListView>

                    <!-- Empty State -->
                    <StackPanel x:Name="EmptyState" Grid.Row="1"
                                VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="Collapsed">
                        <FontIcon Glyph="&#xE773;" FontSize="48"
                                  Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                  HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock Text="No products found" FontSize="16" FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Try adjusting your search or filters"
                                   FontSize="13"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Status Bar -->
            <Grid Grid.Row="4" Margin="0,10,0,0">
                <TextBlock x:Name="StatusText" FontSize="12"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
            </Grid>
        </Grid>

        <!-- ==================== Dialogs ==================== -->

        <!-- Crop Dialog -->
        <ContentDialog x:Name="CropDialog" Title="Crop Image"
                       PrimaryButtonText="Crop" CloseButtonText="Cancel"
                       DefaultButton="Primary">
            <Grid Width="500" Height="500">
                <Canvas x:Name="CropCanvas" Width="500" Height="500"
                        Background="Black"
                        PointerPressed="CropCanvas_PointerPressed"
                        PointerMoved="CropCanvas_PointerMoved"
                        PointerReleased="CropCanvas_PointerReleased">
                    <!-- Source image -->
                    <Image x:Name="CropImage" Stretch="Uniform"/>

                    <!-- Dark overlays (outside crop area) -->
                    <Rectangle x:Name="OverlayTop" Fill="#80000000"/>
                    <Rectangle x:Name="OverlayBottom" Fill="#80000000"/>
                    <Rectangle x:Name="OverlayLeft" Fill="#80000000"/>
                    <Rectangle x:Name="OverlayRight" Fill="#80000000"/>

                    <!-- Crop selection border -->
                    <Rectangle x:Name="CropRect" Stroke="White" StrokeThickness="2"
                               Fill="Transparent" StrokeDashArray="4 2"/>

                    <!-- Corner handles -->
                    <Border x:Name="HandleTL" Width="16" Height="16" CornerRadius="8"
                            Background="White" BorderBrush="Gray" BorderThickness="1"
                            PointerPressed="Handle_PointerPressed"
                            PointerMoved="Handle_PointerMoved"
                            PointerReleased="Handle_PointerReleased"/>
                    <Border x:Name="HandleTR" Width="16" Height="16" CornerRadius="8"
                            Background="White" BorderBrush="Gray" BorderThickness="1"
                            PointerPressed="Handle_PointerPressed"
                            PointerMoved="Handle_PointerMoved"
                            PointerReleased="Handle_PointerReleased"/>
                    <Border x:Name="HandleBL" Width="16" Height="16" CornerRadius="8"
                            Background="White" BorderBrush="Gray" BorderThickness="1"
                            PointerPressed="Handle_PointerPressed"
                            PointerMoved="Handle_PointerMoved"
                            PointerReleased="Handle_PointerReleased"/>
                    <Border x:Name="HandleBR" Width="16" Height="16" CornerRadius="8"
                            Background="White" BorderBrush="Gray" BorderThickness="1"
                            PointerPressed="Handle_PointerPressed"
                            PointerMoved="Handle_PointerMoved"
                            PointerReleased="Handle_PointerReleased"/>
                </Canvas>
            </Grid>
        </ContentDialog>

        <ContentDialog x:Name="AddProductDialog" Title="Add New Product"
                       PrimaryButtonText="Add" CloseButtonText="Cancel"
                       DefaultButton="Primary"
                       PrimaryButtonClick="AddDialog_PrimaryClick">
            <StackPanel Spacing="16" MinWidth="420" Margin="0,8,0,0">
                <!-- Image Picker -->
                <Grid x:Name="DlgImageDropZone" Height="120" CornerRadius="8"
                      Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                      BorderThickness="1" AllowDrop="True"
                      DragOver="DlgImageDropZone_DragOver"
                      Drop="DlgImageDropZone_Drop">
                    <Image x:Name="DlgImagePreview" Stretch="Uniform" MaxHeight="110"
                           Visibility="Collapsed"/>
                    <StackPanel x:Name="DlgImagePlaceholder" VerticalAlignment="Center"
                                HorizontalAlignment="Center" Spacing="4">
                        <FontIcon Glyph="&#xE722;" FontSize="24"
                                  HorizontalAlignment="Center"
                                  Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                        <TextBlock Text="Drag an image here or" FontSize="12"
                                   HorizontalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <HyperlinkButton Content="Browse files" Click="BrowseImage_Click"
                                         HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <TextBox x:Name="DlgName" Header="Product Name"
                         PlaceholderText="e.g. Wireless Mouse"/>
                <ComboBox x:Name="DlgCategory" Header="Category"
                          IsEditable="True" PlaceholderText="Select or type..."
                          HorizontalAlignment="Stretch">
                    <ComboBoxItem Content="Electronics"/>
                    <ComboBoxItem Content="Accessories"/>
                    <ComboBoxItem Content="Furniture"/>
                    <ComboBoxItem Content="Stationery"/>
                </ComboBox>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <NumberBox x:Name="DlgPrice" Grid.Column="0" Header="Price ($)"
                               Minimum="0" SpinButtonPlacementMode="Compact"
                               SmallChange="1" LargeChange="10"/>
                    <NumberBox x:Name="DlgStock" Grid.Column="2" Header="Stock Qty"
                               Minimum="0" SpinButtonPlacementMode="Compact"
                               SmallChange="1" LargeChange="50"/>
                </Grid>
                <TextBox x:Name="DlgDesc" Header="Description"
                         PlaceholderText="Short description..."
                         AcceptsReturn="True" TextWrapping="Wrap" MinHeight="72"/>
            </StackPanel>
        </ContentDialog>
    </Grid>
</Window>
